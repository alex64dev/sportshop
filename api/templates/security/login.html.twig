{% extends 'base.html.twig' %}

{% block title %}Administration HandShop{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #1a1a2e;
            --accent: #e94560;
            --dark: #111111;
            --light: #ffffff;
            --gray-100: #f3f4f6;
            --gray-400: #9ca3af;
        }

        body {
            font-family: 'Manrope', sans-serif;
            overflow-x: hidden;
            background-color: var(--light);
        }

        .login-wrapper {
            min-height: 100vh;
            display: flex;
            flex-direction: row;
        }

        .brand-section {
            background-color: var(--primary);
            background-image:
                radial-gradient(at 0% 0%, hsla(244, 30%, 20%, 1) 0, transparent 50%),
                radial-gradient(at 100% 100%, hsla(0, 0%, 0%, 1) 0, transparent 50%);
            color: var(--light);
            width: 45%;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }

        .brand-section::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            width: 6px;
            background: var(--accent);
            box-shadow: -5px 0 20px rgba(233, 69, 96, 0.3);
        }

        .brand-content h1 {
            font-weight: 800;
            font-size: 3.5rem;
            line-height: 1.1;
            letter-spacing: -1px;
            margin-bottom: 1rem;
        }

        .form-section {
            width: 55%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background-color: var(--light);
        }

        .form-container {
            width: 100%;
            max-width: 420px;
        }

        .form-title {
            font-weight: 700;
            color: var(--dark);
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .form-floating > .form-control {
            border: 2px solid var(--gray-100);
            background-color: var(--gray-100);
            border-radius: 12px;
            height: 4rem;
            font-weight: 600;
            color: var(--dark);
            font-size: 1rem;
        }

        .form-floating > label {
            color: var(--gray-400);
            font-weight: 500;
            padding-top: 1.2rem;
        }

        .form-control:focus {
            background-color: var(--light);
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(26, 26, 46, 0.1);
        }

        .btn-modern {
            background-color: var(--primary);
            border: none;
            color: white;
            height: 3.5rem;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            margin-top: 1rem;
        }

        .btn-modern:hover {
            color: var(--accent);
            background-color: #0f0f1e;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(26, 26, 46, 0.2);
        }

        @media (max-width: 992px) {
            .login-wrapper {
                flex-direction: column;
            }

            .brand-section {
                width: 100%;
                padding: 2rem;
                min-height: 200px;
                justify-content: center;
                text-align: center;
            }

            .brand-content, .brand-footer {
                display: none;
            }

            .form-section {
                width: 100%;
                padding: 2rem 1.5rem;
                flex-grow: 1;
                align-items: flex-start;
            }

            .form-container {
                margin-top: 1rem;
            }

            .brand-header div {
                font-size: 1.8rem !important;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="login-wrapper">
        <div class="brand-section">
            <div class="brand-header">
                <div style="font-weight: 800; font-size: 1.8rem; letter-spacing: -1px; line-height: 1.2;">
                    HANDSHOP
                </div>
            </div>

            <div class="brand-content">
                <h1>GÉRER<br><span style="color: var(--accent);">LA BOUTIQUE</span><br>DU CLUB.</h1>
                <p>Bienvenue sur l'interface d'administration de la boutique HandShop.</p>
            </div>

            <div class="brand-footer" style="font-size: 0.8rem; opacity: 0.5;">
                &copy; {{ "now"|date("Y") }} HandShop — Tous droits réservés.
            </div>
        </div>

        <div class="form-section">
            <div class="form-container">
                <h2 class="form-title">Connexion</h2>
                <p class="form-subtitle">Saisissez vos identifiants pour accéder au tableau de bord.</p>

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} d-flex align-items-center" role="alert" style="border-radius: 12px; font-size: 0.9rem;">
                            <div>{{ message }}</div>
                        </div>
                    {% endfor %}
                {% endfor %}

                {% if error %}
                    <div class="alert alert-danger d-flex align-items-center" role="alert" style="border-radius: 12px; font-size: 0.9rem;">
                        <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    </div>
                {% endif %}

                <form method="post" action="{{ path('app_login') }}">
                    <div class="form-floating mb-3">
                        <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" placeholder="name@example.com" autocomplete="email" required autofocus>
                        <label for="username">Adresse Email</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input type="password" name="_password" id="password" class="form-control" placeholder="Password" autocomplete="current-password" required>
                        <label for="password">Mot de passe</label>
                    </div>

                    <div class="d-flex justify-content-end mb-3">
                        <a href="{{ path('app_forgot_password_request') }}" style="color: var(--primary); text-decoration: none; font-weight: 600; font-size: 0.9rem;">
                            Mot de passe oublié ?
                        </a>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="d-grid">
                        <button class="btn btn-modern" type="submit">ACCÉDER À L'ESPACE</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
