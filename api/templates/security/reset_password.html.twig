{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #1a1a2e; --accent: #e94560; --dark: #111111; --light: #ffffff; --gray-100: #f3f4f6; --gray-400: #9ca3af; }
        body { font-family: 'Manrope', sans-serif; background-color: var(--light); }
        .login-wrapper { min-height: 100vh; display: flex; flex-direction: row; }
        .brand-section {
            background-color: var(--primary);
            background-image: radial-gradient(at 0% 0%, hsla(244, 30%, 20%, 1) 0, transparent 50%), radial-gradient(at 100% 100%, hsla(0, 0%, 0%, 1) 0, transparent 50%);
            color: var(--light); width: 45%; display: flex; flex-direction: column; justify-content: center; padding: 3rem; position: relative; overflow: hidden;
        }
        .brand-section::after { content: ''; position: absolute; top: 0; right: 0; bottom: 0; width: 6px; background: var(--accent); }
        .form-section { width: 55%; display: flex; align-items: center; justify-content: center; padding: 2rem; }
        .form-container { width: 100%; max-width: 420px; }
        .form-title { font-weight: 700; color: var(--dark); font-size: 2rem; margin-bottom: 0.5rem; }
        .form-floating > .form-control { border: 2px solid var(--gray-100); background-color: var(--gray-100); border-radius: 12px; height: 4rem; font-weight: 600; }
        .form-floating > label { color: var(--gray-400); padding-top: 1.2rem; }
        .form-control:focus { background-color: var(--light); border-color: var(--primary); box-shadow: 0 0 0 4px rgba(26, 26, 46, 0.1); }
        .btn-modern { background-color: var(--primary); border: none; color: white; height: 3.5rem; border-radius: 12px; font-weight: 700; margin-top: 1rem; width: 100%; }
        .btn-modern:hover { color: var(--accent); background-color: #0f0f1e; }
        @media (max-width: 992px) { .login-wrapper { flex-direction: column; } .brand-section { width: 100%; min-height: 150px; padding: 2rem; } .form-section { width: 100%; } }
    </style>
{% endblock %}

{% block body %}
    <div class="login-wrapper">
        <div class="brand-section">
            <h1 style="font-weight: 800; font-size: 3rem; line-height: 1.1;">SÉCURITÉ<br><span style="color: var(--accent);">RENFORCÉE</span></h1>
        </div>

        <div class="form-section">
            <div class="form-container">
                <h2 class="form-title">Nouveau mot de passe</h2>
                <p class="mb-4 text-muted">Choisissez un mot de passe sécurisé.</p>

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} mb-4">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                <form method="post">
                    <div class="form-floating mb-3">
                        <input type="password" name="password" id="password" class="form-control" placeholder="Nouveau mot de passe" required>
                        <label for="password">Nouveau mot de passe</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="password" name="password_confirm" id="password_confirm" class="form-control" placeholder="Confirmer" required>
                        <label for="password_confirm">Confirmer le mot de passe</label>
                    </div>

                    <button class="btn btn-modern" type="submit">MODIFIER</button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
